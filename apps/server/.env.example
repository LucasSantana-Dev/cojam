# CoJam server configuration. Copy to .env (or export) for local development.
# Every value here is optional: with none set, the server runs with in-memory
# rooms and only the always-on providers. Feature flags default to on unless a
# noted dependency (an API key) is missing.

# --- Persistence ---
# When set, room state (queue, now-playing, radio) is persisted to Postgres and
# survives restarts. Unset = in-memory rooms (fine for local dev, lost on restart).
# If set but unreachable, the server exits rather than silently losing durability.
# Migrations run automatically on startup.
# DATABASE_URL=postgres://user:pass@127.0.0.1:5432/cojam

# --- CORS ---
# Comma-separated allowed origins. Empty defaults to local dev origins
# (http://localhost:3000 and http://127.0.0.1:3000).
# CORS_ORIGINS=https://cojam.example.com

# --- Track matching / search (FEATURE_MATCHING, default on) ---
# YouTube Data API key enables the YouTube source matcher.
# YOUTUBE_API_KEY=
# Spotify Client Credentials enable the Spotify matcher.
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# --- Radio auto-refill (FEATURE_RADIO, default on; needs a key to activate) ---
# LASTFM_API_KEY=

# --- Feature toggles (1/true/on/yes or 0/false/off/no; unset = default) ---
# FEATURE_MATCHING=on
# FEATURE_PLAYLIST_IMPORT=on
# FEATURE_RADIO=on
# FEATURE_TRACK_DEPTH=on
# FEATURE_LYRICS=on

# CoJam server configuration. Copy to .env (or export) for local development.
# Every value here is optional: with none set, the server runs with in-memory
# rooms and only the always-on providers. Feature flags default to on unless a
# noted dependency (an API key) is missing.

# --- Persistence ---
# When set, room state (queue, now-playing, radio) is persisted to Postgres and
# survives restarts. Unset = in-memory rooms (fine for local dev, lost on restart).
# If set but unreachable, the server exits rather than silently losing durability.
# Migrations run automatically on startup. A pooled/PgBouncer URL works as-is.
# DATABASE_URL=postgres://user:pass@127.0.0.1:5432/cojam
# Optional direct (non-pooled) URL used only for running migrations, in case the
# provider's pooler restricts DDL. Runtime queries always use DATABASE_URL.
# DIRECT_DATABASE_URL=postgres://user:pass@direct-host:5432/cojam

# --- CORS ---
# Comma-separated allowed origins. Empty defaults to local dev origins
# (http://localhost:3000 and http://127.0.0.1:3000).
# CORS_ORIGINS=https://cojam.example.com

# --- Track matching / search (FEATURE_MATCHING, default on) ---
# YouTube Data API key enables the YouTube source matcher.
# YOUTUBE_API_KEY=
# Spotify Client Credentials enable the Spotify matcher.
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# --- Radio auto-refill (FEATURE_RADIO, default on; needs a key to activate) ---
# LASTFM_API_KEY=

# --- Feature toggles (1/true/on/yes or 0/false/off/no; unset = default) ---
# FEATURE_MATCHING=on
# FEATURE_PLAYLIST_IMPORT=on
# FEATURE_RADIO=on
# FEATURE_TRACK_DEPTH=on
# FEATURE_LYRICS=on
# FEATURE_SYNC=on  # synchronized playback (transport RPCs); default off
# FEATURE_ROOM_CHAT=on  # ephemeral in-memory room chat (chat.send/chat.history); default off

# --- Accounts via Supabase Auth (FEATURE_SUPABASE_AUTH, default off) ---
# When on, a connection token that validates as a Supabase access token gives the
# client a stable "sb:<user-uuid>" identity (checked before FEATURE_ROOM_AUTH).
# The web app signs users in with Supabase and passes the access token on connect.
# SUPABASE_URL is the project URL (https://<ref>.supabase.co); access tokens are
# verified against its JWKS (new projects sign with ES256). SUPABASE_JWT_SECRET is
# the legacy shared secret (Settings > JWT Keys > Legacy JWT Secret) and is only
# needed for projects still issuing HS256 tokens.
# The profiles/connected_services migration also runs on startup, so DATABASE_URL
# should point at the same Supabase project (pooled URL works; DIRECT_DATABASE_URL
# is used for the DDL).
# FEATURE_SUPABASE_AUTH=on
# SUPABASE_URL=
# SUPABASE_JWT_SECRET=

# Multi-stage build for Next.js web app
# Stage 1: Build
FROM node:22-alpine AS builder

WORKDIR /build

# Install pnpm
RUN npm install -g pnpm

# Copy root package files and workspace manifest
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

# Copy all workspace packages
COPY packages ./packages
COPY apps/web ./apps/web
COPY apps/server ./apps/server

# Install dependencies
RUN pnpm install --frozen-lockfile

# Build web app (generates standalone output)
RUN pnpm --filter web build

# Stage 2: Runtime (minimal Node image)
FROM node:22-alpine

WORKDIR /app

# Copy standalone server from builder
COPY --from=builder /build/apps/web/.next/standalone ./

# Copy public assets if they exist
COPY --from=builder /build/apps/web/public ./public

# Expose port
EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:3000 || exit 1

# Environment: NODE_ENV must be production for Next standalone
ENV NODE_ENV=production

# Run Next.js app (server.js is generated by Next standalone build)
ENTRYPOINT ["node", "server.js"]
